# Environment variables for Automaton Auditor
# Copy this file to .env and fill in your actual API keys
# 
# IMPORTANT: Never commit .env file to version control!

# ============================================
# LangSmith Tracing (Observability)
# ============================================
# Enable LangSmith tracing for full visibility into agent execution
# Get your API key from: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=automaton-auditor

# ============================================
# LLM Provider API Keys
# ============================================
# Choose one provider (OpenAI or Anthropic)

# OpenAI (for langchain-openai)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OR use Anthropic (for langchain-anthropic)
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# ============================================
# Optional: Vision Models (for VisionInspector)
# ============================================
# If using VisionInspector for diagram analysis, add:
# GOOGLE_API_KEY=your_gemini_api_key_here
# Or use OpenAI Vision:
# OPENAI_API_KEY=your_openai_api_key_here  # (same as above)

# ============================================
# Optional Configuration
# ============================================
# LOG_LEVEL=INFO
# MAX_WORKERS=4
